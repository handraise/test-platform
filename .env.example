# AI test runner
ANTHROPIC_API_KEY=

# Base URL for naapp on stage2 (no trailing slash).
# E2E_BASE_URL is kept for test-platform; NAAPP_BASE_URL is accepted for e2e-handraise compatibility.
E2E_BASE_URL=https://naapp-stage2.handraise.site
NAAPP_BASE_URL=https://naapp-stage2.handraise.site

# REST login endpoint (relative to the Playwright base URL or absolute).
NAAPP_AUTH_URL=/api/auth/login

# Preferred E2E credential names.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Existing test-platform names are also supported.
HANDRAISE_EMAIL=
HANDRAISE_PASSWORD=

# Optional: override auth storage path (default: .auth/user.json).
# E2E_AUTH_STATE_PATH=.auth/user.json
